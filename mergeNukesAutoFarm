local playerService = game:GetService("Players")
local localPlayer = playerService.LocalPlayer
local hrp = localPlayer.Character:FindFirstChild("HumanoidRootPart")
local bases = game.Workspace.Bases
local restPosition = CFrame.new(403.90, 13.59, 252.84, -1, -0, -0.05, -0, 1, -0, 0.05, -0, -1)


setrobloxinput(true)
local function getBase()
    for i,v in pairs(bases:GetChildren()) do
        if v:FindFirstChild("Floor") and v.Floor:FindFirstChild("BillboardGui") and v.Floor.BillboardGui:FindFirstChild("TextLabel") then
            if v.Floor.BillboardGui.TextLabel.Text == localPlayer.Name then
                print("Found base", v.Name)
                return v
            end
        end
    end
end

local base = getBase()

local function grabNuke(nuke)
    local nukePosition = nuke.Position
    local hrpPosition = hrp.Position

    hrp.Position = nukePosition
    print("Finished grabbing")
end

local nukes = {}
local function scanNukes()
    if base == nil or not base then
        notify("BASE IS NIL")
    end
    print("Scanning nukes")
    nukes = {}
    print(base.Nukes)
    for _, descendent in pairs(base.Nukes:GetDescendants()) do
        print("Scanning descendent", descendent.Name)
        if descendent.Name == "TextLabel" then
            local key = descendent.Text

            if not nukes[key] then
                nukes[key] = {descendent.Parent.Parent}
            else
                table.insert(nukes[key], descendent.Parent.Parent)
            end
        end
    end
    print("Finished scanning nukes")
end

