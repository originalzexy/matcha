local dropButton = localPlayer.PlayerGui.ScreenGui.HoldingFrame.Drop.TextButton

local function mergeNukes()
    working = true
    scanNukes()
    print("Starting merge in 1 second")
    task.wait(1)
    for nukeStrength, nukeList in pairs(nukes) do
        print("Merging nukes of strength", nukeStrength)
        for i = 1, #nukeList - 1, 2 do
            mousemoveabs(dropButton.AbsolutePosition.X + dropButton.AbsoluteSize.X / 2, dropButton.AbsolutePosition.Y + dropButton.AbsoluteSize.Y / 2)
            task.wait(0.1)
            mouse1click()
            task.wait(0.5)
            -- if nukeGrabbed and nukeHeld.OverheadNuke.TextLabel ~= nukeStrength then
            --     print("Accidently picked up nuke, dropping it")
            --     mousemoveabs(localPlayer.PlayerGui.ScreenGui.HoldingFrame.Drop.TextButton.AbsolutePosition.X, localPlayer.PlayerGui.ScreenGui.HoldingFrame.Drop.TextButton.AbsolutePosition.Y)
            --     mouse1click()
            -- end
            local first = nukeList[i]
            local second = nukeList[i + 1]
            print("Grabbing nukes", first.Name, "and", second.Name)

            grabNuke(first)
            task.wait(0.5)
            grabNuke(second)
            task.wait(0.5)

            hrp.CFrame = restPosition + Vector3.new(0, 3, 0)
        end
    end
    working = false
end

local autoFarmActive = false
local working = false

UI.AddTab("Merge Nukes", function(tab)
    local autoFarm = tab:Section("AutoFarm", "Left")
    
    autoFarm:Toggle("autofarm_on", "Autofarm", function(state)
